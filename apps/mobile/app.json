{
  "expo": {
    "name": "Verify Me",
    "slug": "verifyme",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "verifyme",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#2563EB"
    },
    "platforms": ["ios", "android"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.verifyme.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#2563EB"
      },
      "package": "com.verifyme.app"
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      "expo-document-picker",
      "expo-secure-store"
    ]
  }
}
