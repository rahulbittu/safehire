# ==============================================================================
# Environment
# ==============================================================================
# Controls security behavior (NOT the same as NODE_ENV):
#   development — dev auth allowed, dev crypto keys allowed (DEFAULT)
#   test        — dev auth allowed (for integration tests)
#   staging     — dev auth BLOCKED, real crypto keys REQUIRED
#   production  — dev auth BLOCKED, real crypto keys REQUIRED
APP_ENV=development
# Must also set NEXT_PUBLIC_ variant for client-side auth mode detection in Next.js
NEXT_PUBLIC_APP_ENV=development

# ==============================================================================
# Supabase — Web (Next.js)
# ==============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase — Server-side
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database
DATABASE_URL=postgresql://postgres:password@localhost:54322/postgres

# ==============================================================================
# Auth
# ==============================================================================
# DEV AUTH: HMAC signing secret for dev tokens.
# Only used when APP_ENV=development or APP_ENV=test.
# In staging/production, dev auth is completely disabled.
DEV_AUTH_SECRET=safehire-dev-secret-change-in-production

# ==============================================================================
# Encryption
# ==============================================================================
# Field-level encryption key (AES-256-GCM, 32 bytes hex-encoded)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# REQUIRED in staging/production. Dev fallback used if not set in development.
FIELD_ENCRYPTION_KEY=

# HMAC hash pepper for identity deduplication
# REQUIRED in staging/production. Dev fallback used if not set in development.
HASH_PEPPER=

# ==============================================================================
# Supabase — Mobile (Expo)
# ==============================================================================
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
